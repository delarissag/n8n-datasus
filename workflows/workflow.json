      "id": "4b37e5e6-0e75-4005-a3eb-129d085ecbcf",
      "name": "Log: Nada a Fazer1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -6192,
        2144
      ]
    },
    {
      "parameters": {
        "jsCode": "const arquivosExistentes = $input.all()\n  .map(item => item.json.nome_arquivo)\n  .filter(a => a && a.startsWith('PAMS'))\n  .map(a => a.replace('.sqlite', ''));\n\nconst INICIO = { ano: 2024, mes: 1 };\n\nconst hoje = new Date();\nconst limite = new Date(hoje.getFullYear(), hoje.getMonth(), 1);\n\n// Gera todos os patterns esperados\nconst mesesEsperados = [];\nlet cursor = new Date(INICIO.ano, INICIO.mes - 1, 1);\n\nwhile (cursor <= limite) {\n  const yy = String(cursor.getFullYear()).slice(-2);\n  const mm = String(cursor.getMonth() + 1).padStart(2, '0');\n  mesesEsperados.push('PAMS' + yy + mm);\n  cursor.setMonth(cursor.getMonth() + 1);\n}\n\nconst faltando = mesesEsperados.filter(p => !arquivosExistentes.includes(p));\n\nif (faltando.length === 0) {\n  return [{ json: { status: 'nada_a_fazer', pattern: null } }];\n}\n\nreturn faltando.map(pattern => ({ json: { status: 'pendente', pattern } }));"
      },
