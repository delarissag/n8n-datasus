        "jsCode": "console.log('[Delta Load] Nenhum arquivo novo encontrado. Pipeline encerrado sem ação.');\nreturn [{ json: { status: 'nada_a_fazer', mensagem: 'Todos os arquivos já foram processados.' } }];"
